<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Wing / Lightning motif with gold gradient -->
    <path
        android:pathData="M120,256 L220,120 L400,120 L300,256 L440,256 L200,440 L260,256 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="512"
                android:endY="512">
                <item android:offset="0" android:color="#FFE792"/>
                <item android:offset="1" android:color="#FFC107"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle white accent -->
    <path
        android:pathData="M180,180 L240,120 L300,120 L210,240 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.1"/>
</vector>
