<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Wing / Lightning motif with gold gradient, centered and scaled to ~50% -->
    <path
        android:pathData="M156,256 L206,180 L300,180 L250,256 L320,256 L230,360 L262,256 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="156"
                android:startY="180"
                android:endX="320"
                android:endY="360">
                <item android:offset="0" android:color="#FFE792"/>
                <item android:offset="1" android:color="#FFC107"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle white accent -->
    <path
        android:pathData="M178,210 L208,180 L250,180 L212,234 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.15"/>
</vector>
